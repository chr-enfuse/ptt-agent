{
  "name": "deck-agent-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend service for the PowerPoint Financial-Deck Agent add-in: holds the Anthropic API key, runs the Messages API tool-use loop, parses Excel deterministically, and performs numeric verification.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:templates": "tsx scripts/build-templates.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.2",
    "pptxgenjs": "^4.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
