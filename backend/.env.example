# OpenRouter API key — the backend holds it; it never reaches the task pane.
OPENROUTER_API_KEY=sk-or-...
# Model served through OpenRouter (any OpenRouter model id; must support tool calling).
MODEL=openai/gpt-oss-20b
# Reasoning effort for models that support it (low | medium | high).
# Raise to medium if tool-calling is flaky on gpt-oss-20b.
REASONING_EFFORT=low
# OpenRouter OpenAI-compatible base URL.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Upper bound on completion tokens per round (reasoning + visible output).
MAX_OUTPUT_TOKENS=32000
# Port the backend listens on (the add-in expects 3001 by default).
PORT=3001
# Comma-separated origins allowed to call this backend (the add-in dev server).
ALLOWED_ORIGINS=https://localhost:3000
