# Copy to .env and fill in. The key lives ONLY on the backend — never in the task pane.
OPENROUTER_API_KEY=sk-or-...

# Model served through OpenRouter (any OpenRouter model id; must support tool calling).
MODEL=openai/gpt-oss-20b

# Optional. Reasoning effort for models that support it (low | medium | high).
# REASONING_EFFORT=high

# Optional. Override the OpenRouter base URL (e.g. a company gateway).
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Port the backend listens on (the add-in expects 3001 by default)
PORT=3001

# Comma-separated origins allowed to call this backend (add-in dev server)
ALLOWED_ORIGINS=https://localhost:3000
